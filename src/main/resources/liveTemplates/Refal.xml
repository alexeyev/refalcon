<templateSet group="Refal">
  <template name="entry"
            value="$$ENTRY Go {&#10;  = $END$;&#10;}"
            description="Refal: program entry point (Go)"
            toReformat="false" toShortenFQNames="false">
    <context>
      <option name="REFAL" value="true"/>
    </context>
  </template>
  <template name="fn"
            value="$NAME$ {&#10;  $PAT$ = $RES$;&#10;}"
            description="Refal: function definition"
            toReformat="false" toShortenFQNames="false">
    <variable name="NAME" expression="" defaultValue="&quot;Func&quot;" alwaysStopAt="true"/>
    <variable name="PAT" expression="" defaultValue="" alwaysStopAt="true"/>
    <variable name="RES" expression="" defaultValue="" alwaysStopAt="true"/>
    <context>
      <option name="REFAL" value="true"/>
    </context>
  </template>
  <template name="prout"
            value="&lt;Prout $END$&gt;"
            description="Refal: print to stdout"
            toReformat="false" toShortenFQNames="false">
    <context>
      <option name="REFAL" value="true"/>
    </context>
  </template>
  <template name="extern"
            value="$$EXTERN $FN$;"
            description="Refal: declare an external function"
            toReformat="false" toShortenFQNames="false">
    <variable name="FN" expression="" defaultValue="&quot;Func&quot;" alwaysStopAt="true"/>
    <context>
      <option name="REFAL" value="true"/>
    </context>
  </template>
  <template name="call"
            value="&lt;$FN$ $ARGS$&gt;$END$"
            description="Refal: function call"
            toReformat="false" toShortenFQNames="false">
    <variable name="FN" expression="" defaultValue="&quot;Func&quot;" alwaysStopAt="true"/>
    <variable name="ARGS" expression="" defaultValue="" alwaysStopAt="true"/>
    <context>
      <option name="REFAL" value="true"/>
    </context>
  </template>
  <template name="proutq"
            value="&lt;Prout '$END$'&gt;"
            description="Refal: print a quoted string to stdout"
            toReformat="false" toShortenFQNames="false">
    <context>
      <option name="REFAL" value="true"/>
    </context>
  </template>
</templateSet>
